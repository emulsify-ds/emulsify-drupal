{#
/**
 * @file
 * Default theme implementation to display a single message in the navigation toolbar.
 *
 * Available variables:
 * - content: The message to display.
 *
 * @ingroup themeable
 */
#}
{% set toolbar_message_block = 'toolbar-message' %}
{%
  set classes = bem(toolbar_message_block, ['type--' ~ type])
%}
{% set navigation_message_link_attributes = {
  class: classes,
  href: url,
  'data-drupal-tooltip': content,
  'data-drupal-tooltip-class': 'admin-toolbar__tooltip',
} %}
{% set navigation_message_attributes = {
  class: classes,
} %}

{% if url is not empty %}
  <a{{ add_attributes(navigation_message_link_attributes) }}>
    {{ icon('navigation', type, { class: 'toolbar-message__icon', size: 20 }) }}
    <div{{ bem('label', [], toolbar_message_block) }}>
      {{ content }}
    </div>
  </a>
{% else %}
  <div{{ add_attributes(navigation_message_attributes) }}>
    {{ icon('navigation', type, { class: 'toolbar-message__icon', size: 20 }) }}
    <div{{ bem('label', [], toolbar_message_block) }}>
      {{ content }}
    </div>
  </div>
{% endif %}
