{#
/**
 * @file
 * Theme override for the administrative toolbar.
 *
 * Available variables:
 * - attributes: HTML attributes for the wrapper.
 * - toolbar_attributes: HTML attributes to apply to the toolbar.
 * - toolbar_heading: The heading or label for the toolbar.
 * - tabs: List of tabs for the toolbar.
 *   - attributes: HTML attributes for the tab container.
 *   - link: Link or button for the menu tab.
 * - trays: Toolbar tray list, each associated with a tab. Each tray in trays
 *   contains:
 *   - attributes: HTML attributes to apply to the tray.
 *   - label: The tray's label.
 *   - links: The tray menu links.
 * - remainder: Any non-tray, non-tab elements left to be rendered.
 *
 * @see \Drupal\toolbar\ToolbarThemeHooks::preprocessToolbar()
 */
#}
{% set toolbar_wrapper_attributes = {
  class: 'toolbar',
} %}
{% set toolbar_nav_attributes = {
  class: ['toolbar-bar', 'clearfix'],
} %}
<div{{ add_attributes(toolbar_wrapper_attributes) }}>
  {% with { attributes: toolbar_attributes } %}
    <nav{{ add_attributes(toolbar_nav_attributes) }}>
    {% set toolbar_heading_attributes = {
      class: 'visually-hidden',
    } %}
    <h2{{ add_attributes(toolbar_heading_attributes) }}>{{ toolbar_heading }}</h2>
    {% for key, tab in tabs %}
      {% set tray = trays[key] %}
      {% with { attributes: tab.attributes } %}
        {% set toolbar_tab_attributes = {
          class: 'toolbar-tab',
        } %}
        <div{{ add_attributes(toolbar_tab_attributes) }}>
          {{ tab.link }}
          <div{{ tray.attributes }}>
            {% if tray.label %}
              {% set toolbar_tray_nav_attributes = {
                class: ['toolbar-lining', 'clearfix'],
                role: 'navigation',
                'aria-label': tray.label,
              } %}
              <nav{{ add_attributes(toolbar_tray_nav_attributes) }}>
                {% set toolbar_tray_name_attributes = {
                  class: ['toolbar-tray-name', 'visually-hidden'],
                } %}
                <h3{{ add_attributes(toolbar_tray_name_attributes) }}>{{ tray.label }}</h3>
            {% else %}
              {% set toolbar_tray_nav_attributes = {
                class: ['toolbar-lining', 'clearfix'],
                role: 'navigation',
              } %}
              <nav{{ add_attributes(toolbar_tray_nav_attributes) }}>
            {% endif %}
            {{- tray.links -}}
            </nav>
          </div>
        </div>
      {% endwith %}
    {% endfor %}
    </nav>
  {% endwith %}
  {{ remainder }}
</div>
