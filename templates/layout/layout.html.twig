{#
/**
 * @file
 * Template for a generic layout.
 */
#}
{%
  set classes = [
    'layout',
    'layout--' ~ layout.id|clean_class,
  ]
%}
{% if content %}
  <div{{ add_attributes({ class: classes }) }}>
    {% for region in layout.getRegionNames %}
      {% if content[region] %}
        {% with { attributes: region_attributes[region] } %}
          <div{{ add_attributes({ class: ['layout__region', 'layout__region--' ~ region|clean_class] }) }}>
            {{ content[region] }}
          </div>
        {% endwith %}
      {% endif %}
    {% endfor %}
  </div>
{% endif %}
